#!/usr/bin/env python3
"""Tray icon showing a live mini history bar of Claude service health."""
import datetime
import fcntl
import glob
import json
import os
import subprocess
import sys
import time
import urllib.request
import webbrowser

import gi

gi.require_version("Gtk", "3.0")
gi.require_version("AyatanaAppIndicator3", "0.1")
gi.require_version("Notify", "0.7")
from gi.repository import AyatanaAppIndicator3 as AppIndicator3
from gi.repository import Gdk, GLib, Gtk, Notify

STATUS_URL = "https://status.claude.com/api/v2/status.json"
COMPONENTS_URL = "https://status.claude.com/api/v2/components.json"
INCIDENTS_URL = "https://status.claude.com/api/v2/incidents/unresolved.json"
CLAUDE_API_COMPONENT_ID = "k8w3r06qmzrp"  # "Claude API (api.anthropic.com)" -- what Opus actually runs on; there's no Opus-specific status feed
STATUS_PAGE = "https://status.claude.com"
POLL_SECONDS = 60

COMPONENT_STATUS_MAP = {
    "operational": "none",
    "degraded_performance": "minor",
    "partial_outage": "major",
    "major_outage": "critical",
    "under_maintenance": "minor",
}

HISTORY_PATH = os.path.expanduser("~/.local/share/claude-status/history.json")
HISTORY_MAX_STORED = 2000  # ~33h of polls at 60s cadence
ICON_BAR_COUNT = 10  # segments drawn inside the tray icon itself (~10min at 60s cadence)

# Installed into the user's real hicolor icon theme (~/.local/share/icons/hicolor)
# instead of an app-private IconThemePath dir: Plasma's SNI icon resolver
# unreliably honors the per-item IconThemePath D-Bus property, but hicolor is
# always searched by both KDE and GTK. Every poll gets a brand-new, never-reused
# icon name (a fixed pool of alternating names got stuck showing a stale cached
# render, since Plasma's QIcon cache is keyed by name only and never rechecks
# the file on disk once it has resolved that name before).
HICOLOR_DIR = os.path.expanduser("~/.local/share/icons/hicolor")
SIZES = tuple(range(12, 65))  # dense so Plasma always finds an exact match instead of smooth-scaling (blurring) a mismatched size
ICON_NAME_PREFIX = "claude-status-live-"
COLORS = {
    "none": (0.20, 0.75, 0.35),      # operational - green
    "minor": (0.95, 0.75, 0.10),     # minor - yellow
    "major": (0.95, 0.50, 0.10),     # major - orange
    "critical": (0.90, 0.15, 0.15),  # critical - red
    "unknown": (0.55, 0.55, 0.55),   # unreachable - gray
}

# Desktop notifications fire on the "operational" <-> "not operational" boundary
# (in either direction), not on every severity change, mirroring the macOS
# app's green/orange/red popup behavior.
NOTIFY_ICON = {
    "none": "dialog-information",
    "minor": "dialog-warning",
    "major": "dialog-warning",
    "critical": "dialog-error",
    "unknown": "dialog-warning",
}


def notify(summary, body, indicator):
    try:
        n = Notify.Notification.new(summary, body, NOTIFY_ICON.get(indicator, "dialog-information"))
        n.set_urgency(
            Notify.Urgency.CRITICAL if indicator in ("major", "critical") else Notify.Urgency.NORMAL
        )
        n.show()
    except Exception:
        pass  # notification daemon unavailable -- non-critical, don't crash the poll loop


def fetch_incidents():
    try:
        with urllib.request.urlopen(INCIDENTS_URL, timeout=10) as resp:
            data = json.loads(resp.read().decode())
        return data.get("incidents", [])
    except Exception:
        return []


def incident_detail(incidents, component_id=None):
    """Return the first unresolved incident affecting component_id (or any
    incident if component_id is None), so the UI can show what's actually
    broken instead of just a severity label."""
    for inc in incidents:
        if component_id is not None:
            comp_ids = {c["id"] for c in inc.get("components", [])}
            if component_id not in comp_ids:
                continue
        updates = inc.get("incident_updates") or []
        latest = max(updates, key=lambda u: u.get("created_at", "")) if updates else None
        return {
            "name": inc.get("name"),
            "status": inc.get("status"),
            "started_at": inc.get("started_at"),
            "shortlink": inc.get("shortlink"),
            "body": latest.get("body") if latest else None,
        }
    return None


def relative_time(iso_str):
    if not iso_str:
        return "unknown"
    try:
        dt = datetime.datetime.fromisoformat(iso_str.replace("Z", "+00:00"))
    except ValueError:
        return "unknown"
    secs = int((datetime.datetime.now(datetime.timezone.utc) - dt).total_seconds())
    if secs < 60:
        return "just now"
    if secs < 3600:
        return f"{secs // 60}m ago"
    if secs < 86400:
        return f"{secs // 3600}h ago"
    return f"{secs // 86400}d ago"


_DOT_PIXBUF_CACHE = {}
DOT_SIZE = 12


def dot_pixbuf(indicator):
    # System tray menus (AppIndicator/dbusmenu) are rendered by the shell
    # over D-Bus, which only carries a plain label string -- Pango markup
    # like <span foreground="..."> gets silently stripped. A per-item icon
    # is the one thing that protocol *does* carry, so severity color has to
    # be conveyed as a small rendered dot rather than colored text.
    if indicator in _DOT_PIXBUF_CACHE:
        return _DOT_PIXBUF_CACHE[indicator]
    import cairo

    r, g, b = COLORS.get(indicator, COLORS["unknown"])
    surface = cairo.ImageSurface(cairo.FORMAT_ARGB32, DOT_SIZE, DOT_SIZE)
    ctx = cairo.Context(surface)
    ctx.set_source_rgba(0, 0, 0, 0)
    ctx.paint()
    ctx.set_source_rgb(r, g, b)
    ctx.arc(DOT_SIZE / 2, DOT_SIZE / 2, DOT_SIZE / 2 - 1, 0, 2 * 3.141592653589793)
    ctx.fill()
    pixbuf = Gdk.pixbuf_get_from_surface(surface, 0, 0, DOT_SIZE, DOT_SIZE)
    _DOT_PIXBUF_CACHE[indicator] = pixbuf
    return pixbuf


def load_history():
    try:
        with open(HISTORY_PATH) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return []


def save_history(history):
    os.makedirs(os.path.dirname(HISTORY_PATH), exist_ok=True)
    tmp_path = HISTORY_PATH + ".tmp"
    with open(tmp_path, "w") as f:
        json.dump(history, f)
    os.replace(tmp_path, HISTORY_PATH)


WIDTH_SCALE = 1.5  # tray icons are wider than tall so segments aren't cramped


def render_row(ctx, history, field, bar_px, gap_px, y0, y1):
    recent = history[-ICON_BAR_COUNT:]
    padded = [None] * (ICON_BAR_COUNT - len(recent)) + recent
    for i, entry in enumerate(padded):
        x0 = i * (bar_px + gap_px)
        x1 = x0 + bar_px
        value = entry.get(field) if entry else None
        if value is None:
            ctx.set_source_rgba(0.5, 0.5, 0.5, 0.35)
        else:
            r, g, b = COLORS.get(value, COLORS["unknown"])
            ctx.set_source_rgb(r, g, b)
        ctx.rectangle(x0, y0, x1 - x0, y1 - y0)
        ctx.fill()


def render_icon(history, size):
    import cairo

    height = size
    target_width = size * WIDTH_SCALE
    gap_px = 1
    # Derive a fixed per-bar pixel width from the target total width, rather
    # than dividing the total by ICON_BAR_COUNT per-bar (which leaves rounding
    # remainders and makes some bars 1px wider than others).
    bar_px = max(1, round((target_width - (ICON_BAR_COUNT - 1) * gap_px) / ICON_BAR_COUNT))
    width = ICON_BAR_COUNT * bar_px + (ICON_BAR_COUNT - 1) * gap_px

    surface = cairo.ImageSurface(cairo.FORMAT_ARGB32, width, height)
    ctx = cairo.Context(surface)
    ctx.set_antialias(cairo.ANTIALIAS_NONE)
    ctx.set_source_rgba(0, 0, 0, 0)
    ctx.paint()

    row_gap = max(2, round(height / 8))
    if (height - row_gap) % 2 != 0:
        row_gap += 1  # keep top/bottom rows exactly equal height rather than off by 1px
    top_h = (height - row_gap) // 2
    render_row(ctx, history, "indicator", bar_px, gap_px, 0, top_h)
    render_row(ctx, history, "api_indicator", bar_px, gap_px, top_h + row_gap, height)

    return surface


def write_icon(history, name):
    for size in SIZES:
        app_dir = os.path.join(HICOLOR_DIR, f"{size}x{size}", "apps")
        os.makedirs(app_dir, exist_ok=True)
        surface = render_icon(history, size)
        surface.write_to_png(os.path.join(app_dir, f"{name}.png"))
    subprocess.run(
        ["gtk-update-icon-cache", "-f", "-t", HICOLOR_DIR],
        capture_output=True,
        check=False,
    )


def cleanup_old_icons(keep_names):
    keep = set(keep_names)
    for size in SIZES:
        app_dir = os.path.join(HICOLOR_DIR, f"{size}x{size}", "apps")
        for path in glob.glob(os.path.join(app_dir, f"{ICON_NAME_PREFIX}*.png")):
            name = os.path.splitext(os.path.basename(path))[0]
            if name not in keep:
                os.remove(path)


class ClaudeStatusIndicator:
    def __init__(self):
        Notify.init("Claude Status")
        self.history = load_history()
        last = self.history[-1] if self.history else None
        self.last_indicator = last.get("indicator") if last else None
        self.last_api_indicator = last.get("api_indicator") if last else None
        self.icon_name = f"{ICON_NAME_PREFIX}{int(time.time() * 1000)}"
        write_icon(self.history, self.icon_name)
        cleanup_old_icons([self.icon_name])

        self.indicator = AppIndicator3.Indicator.new(
            "claude-status",
            self.icon_name,
            AppIndicator3.IndicatorCategory.APPLICATION_STATUS,
        )
        self.indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
        self.indicator.set_title("Claude Status")

        self.menu = Gtk.Menu()

        # ImageMenuItem, not plain MenuItem: severity color has to travel as a
        # per-item icon (see dot_pixbuf) since the dbusmenu protocol used by
        # AppIndicator/Plasma strips Pango markup from labels, and insensitive
        # items get forced to the theme's disabled-gray regardless of markup.
        self.status_item = Gtk.ImageMenuItem(label="Checking...")
        self.status_item.set_always_show_image(True)
        self.menu.append(self.status_item)

        self.api_status_item = Gtk.ImageMenuItem(label="Checking...")
        self.api_status_item.set_always_show_image(True)
        self.menu.append(self.api_status_item)

        self.issue_item = Gtk.ImageMenuItem()
        self.issue_item.set_always_show_image(True)
        self.issue_item.set_no_show_all(True)  # only shown while an issue is active; menu.show_all() below must skip it
        self.issue_shortlink = None
        self.issue_item.connect("activate", lambda _: self.issue_shortlink and webbrowser.open(self.issue_shortlink))
        self.menu.append(self.issue_item)

        self.issue_subtitle_item = Gtk.MenuItem()
        self.issue_subtitle_item.set_sensitive(False)  # deliberately grayed -- doubles as the dim "subtitle" styling
        self.issue_subtitle_item.set_no_show_all(True)
        self.menu.append(self.issue_subtitle_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        refresh_item = Gtk.MenuItem(label="Refresh Now")
        refresh_item.connect("activate", lambda _: self.poll())
        self.menu.append(refresh_item)

        open_item = Gtk.MenuItem(label="Open Status Page")
        open_item.connect("activate", lambda _: webbrowser.open(STATUS_PAGE))
        self.menu.append(open_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        quit_item = Gtk.MenuItem(label="Quit")
        quit_item.connect("activate", lambda _: Gtk.main_quit())
        self.menu.append(quit_item)

        self.menu.show_all()
        self.indicator.set_menu(self.menu)

        self.poll()
        GLib.timeout_add_seconds(POLL_SECONDS, self._poll_cb)

    def _poll_cb(self):
        self.poll()
        return True

    def poll(self):
        try:
            with urllib.request.urlopen(STATUS_URL, timeout=10) as resp:
                data = json.loads(resp.read().decode())
            indicator = data["status"]["indicator"]
            description = data["status"]["description"]
        except Exception as exc:
            indicator = "unknown"
            description = f"Unable to reach status page ({exc})"

        try:
            with urllib.request.urlopen(COMPONENTS_URL, timeout=10) as resp:
                data = json.loads(resp.read().decode())
            component = next(
                c for c in data["components"] if c["id"] == CLAUDE_API_COMPONENT_ID
            )
            api_indicator = COMPONENT_STATUS_MAP.get(component["status"], "unknown")
            api_status_word = component["status"].replace("_", " ").title()
            api_description = f"{component['name']}: {api_status_word}"
        except Exception as exc:
            api_indicator = "unknown"
            api_status_word = "Unavailable"
            api_description = f"Claude API: unavailable ({exc})"

        name = indicator if indicator in COLORS else "unknown"
        api_name = api_indicator if api_indicator in COLORS else "unknown"

        def set_status_row(item, prefix, status_word, sev):
            item.set_label(f"{prefix}    {status_word}")
            item.set_image(Gtk.Image.new_from_pixbuf(dot_pixbuf(sev)))

        set_status_row(self.status_item, "Overall", description, name)
        set_status_row(self.api_status_item, "Claude API", api_status_word, api_name)

        # Fetch what's actually broken (mirrors the macOS app's click-through
        # incident detail) only when something is degraded -- no point paying
        # for a second request while everything's operational.
        incidents = fetch_incidents() if (name != "none" or api_name != "none") else []
        overall = incident_detail(incidents) if name != "none" else None
        api_detail = incident_detail(incidents, component_id=CLAUDE_API_COMPONENT_ID) if api_name != "none" else None

        # Surface whichever of the two indicators is currently worse as a single
        # colored card, so its color matches the more severe of the two rows.
        SEVERITY_RANK = {"none": 0, "minor": 1, "major": 2, "critical": 3, "unknown": 4}
        if SEVERITY_RANK.get(api_name, 4) >= SEVERITY_RANK.get(name, 4):
            issue_indicator, issue_detail, issue_fallback = api_name, api_detail, api_description
        else:
            issue_indicator, issue_detail, issue_fallback = name, overall, description

        if issue_indicator == "none":
            self.issue_item.hide()
            self.issue_subtitle_item.hide()
            self.issue_shortlink = None
        else:
            if issue_detail:
                title = issue_detail["name"]
                status_word = (issue_detail["status"] or "").replace("_", " ").title()
                started = relative_time(issue_detail["started_at"])
                subtitle = f"{status_word} · Started {started}" if status_word else f"Started {started}"
                self.issue_shortlink = issue_detail["shortlink"]
            else:
                title = issue_fallback
                subtitle = None
                self.issue_shortlink = None
            self.issue_item.set_label(title)
            self.issue_item.set_image(Gtk.Image.new_from_pixbuf(dot_pixbuf(issue_indicator)))
            self.issue_item.set_sensitive(bool(self.issue_shortlink))
            self.issue_item.show()
            if subtitle:
                self.issue_subtitle_item.set_label(subtitle)
                self.issue_subtitle_item.show()
            else:
                self.issue_subtitle_item.hide()

        def notify_body(base_description, detail):
            if not detail:
                return base_description
            return f"{detail['name']}\n{detail['body']}" if detail["body"] else detail["name"]

        if self.last_indicator is not None and name != self.last_indicator:
            if self.last_indicator == "none":
                notify("Claude Status: Degraded", notify_body(description, overall), name)
            elif name == "none":
                notify("Claude Status: Back to Normal", description, name)
        if self.last_api_indicator is not None and api_name != self.last_api_indicator:
            if self.last_api_indicator == "none":
                notify("Claude API: Degraded", notify_body(api_description, api_detail), api_name)
            elif api_name == "none":
                notify("Claude API: Back to Normal", api_description, api_name)
        self.last_indicator = name
        self.last_api_indicator = api_name

        self.history.append({
            "ts": datetime.datetime.now(datetime.timezone.utc).isoformat(),
            "indicator": name,
            "api_indicator": api_name,
        })
        self.history = self.history[-HISTORY_MAX_STORED:]
        save_history(self.history)

        previous_icon_name = self.icon_name
        self.icon_name = f"{ICON_NAME_PREFIX}{int(time.time() * 1000)}"
        write_icon(self.history, self.icon_name)
        self.indicator.set_icon_full(self.icon_name, f"{description} | {api_description}")
        cleanup_old_icons([self.icon_name, previous_icon_name])


LOCK_PATH = os.path.expanduser("~/.local/share/claude-status/claude-status.lock")


def acquire_single_instance_lock():
    os.makedirs(os.path.dirname(LOCK_PATH), exist_ok=True)
    lock_file = open(LOCK_PATH, "w")
    try:
        fcntl.flock(lock_file, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        return None
    return lock_file  # keep a reference alive for the process lifetime; released on exit


def main():
    lock_file = acquire_single_instance_lock()
    if lock_file is None:
        print("claude-status is already running; exiting.", file=sys.stderr)
        sys.exit(0)

    ClaudeStatusIndicator()
    Gtk.main()


if __name__ == "__main__":
    main()
